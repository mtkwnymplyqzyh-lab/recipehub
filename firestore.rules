rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      allow list: if false;
      allow get: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) 
                     && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio']);
      
      function isValidUser(data) {
        return data.userId == request.auth.uid
          && data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100
          && (data.email is string && data.email.size() > 0)
          && (!('bio' in data) || (data.bio is string && data.bio.size() < 500))
          && (data.createdAt is string); // simplified for now, usually request.time
      }

      // --- Favorites Subcollection ---
      match /favorites/{recipeId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- Recipes ---
    match /recipes/{recipeId} {
      allow list: if resource.data.isPublic == true || (isSignedIn() && resource.data.authorId == request.auth.uid);
      allow get: if resource.data.isPublic == true || (isSignedIn() && resource.data.authorId == request.auth.uid);
      allow create: if isSignedIn() && isValidRecipe(incoming()) && incoming().authorId == request.auth.uid;
      allow update: if isSignedIn() && (
        // Action: Edit content (Owner only)
        (existing().authorId == request.auth.uid && isValidRecipe(incoming()) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'ingredients', 'instructions', 'prepTime', 'imageUrl', 'category', 'isPublic', 'updatedAt', 'cuisine', 'secretTip'])) ||
        // Action: Like/Unlike (Anyone signed in)
        (incoming().diff(existing()).affectedKeys().hasOnly(['likesCount']) && 
         (incoming().likesCount == existing().likesCount + 1 || incoming().likesCount == existing().likesCount - 1))
      );
      allow delete: if isSignedIn() && existing().authorId == request.auth.uid;

      function isValidRecipe(data) {
        return data.title is string && data.title.size() > 0 && data.title.size() < 200
          && data.description is string && data.description.size() < 2000
          && data.ingredients is list && data.ingredients.size() > 0 && data.ingredients.size() <= 100
          && data.instructions is list && data.instructions.size() > 0 && data.instructions.size() <= 50
          && data.prepTime is int && data.prepTime >= 0
          && data.authorId == request.auth.uid
          && data.isPublic is bool
          && data.category is string && data.category.size() > 0 && data.category.size() <= 100
          && (!('cuisine' in data) || (data.cuisine is string && data.cuisine.size() <= 100))
          && (!('secretTip' in data) || (data.secretTip is string && data.secretTip.size() <= 1000));
      }
    }
  }
}
